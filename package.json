    "lodash": "^4.17.21",
    "mitt": "^3.0.1",
    "mqtt": "^5.3.4",
    "quasar": "^2.14.2",
    "vue": "^3.4.18",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@quasar/app-vite": "^2.4.1",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.20.1",
    "git-directory-deploy": "^1.5.1",
    "sass": "^1.70.0",
    "vite": "^5.0.12",
    "vitest": "^1.6.1"
  },
